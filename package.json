{
  "name": "dayone-headless",
  "version": "0.0.0",
  "description": "Headless, Mac-free, read-only Day One client — CLI + MCP server over a local decrypted mirror.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "daytwo": "./src/serve/cli.ts"
  },
  "scripts": {
    "cli": "bun run src/serve/cli.ts",
    "mcp": "bun run src/serve/mcp.ts",
    "sync": "bun run src/ingest/rest/sync.ts",
    "import": "bun run src/ingest/json-export/import.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src test scripts",
    "format": "biome check --write src test scripts",
    "test": "bun test",
    "check": "bun run typecheck && bun run lint && bun test",
    "prepare": "command -v lefthook >/dev/null 2>&1 && lefthook install || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/bun": "^1.3.0",
    "lefthook": "^2.1.10",
    "playwright-core": "^1.61.1",
    "typescript": "^5.6.0"
  }
}
