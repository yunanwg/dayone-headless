{
  "name": "dayone-headless",
  "version": "0.0.0",
  "description": "Headless, Mac-free, read-only Day One client — CLI + MCP server over a local decrypted mirror.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "dayone": "./src/serve/cli.ts"
  },
  "scripts": {
    "cli": "bun run src/serve/cli.ts",
    "import": "bun run src/ingest/json-export/import.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "playwright-core": "^1.61.1",
    "typescript": "^5.6.0"
  }
}
