# Tier A ingester config. Copy to `.env` (gitignored) and fill in.
# NEVER commit real values. The passphrase decrypts the ENTIRE journal — treat
# the profile dir and this file like a private key at rest.

# Persistent Chromium profile (gitignored). Log in once headed; the session
# (and the encryption passphrase's unlocked state) persists here.
DAYONE_PROFILE_DIR=./profile

# 0 = headed (needed for the one-time manual login), 1 = headless (unattended).
DAYONE_HEADLESS=0

# Optional: path to a chromium binary. If unset, the system Chrome is used.
# DAYONE_CHROMIUM=/usr/bin/chromium

# Optional: mirror db path (default: mirror.db).
# DAYONE_MIRROR=./mirror.db

# Completeness gate: 1 (default) refuses to write a partial mirror; 0 overrides.
# DAYONE_STRICT=1

# --- Automated login (SCAFFOLD — selectors not yet wired, see login.ts) ---
# Use the typeable encryption-passphrase path, NOT Apple/Secure-Enclave 2FA.
# DAYONE_AUTOMATED_LOGIN=1
# DAYONE_EMAIL=
# DAYONE_PASSWORD=
# DAYONE_PASSPHRASE=


# ============================================================================
# Tier C — pure REST, no browser (src/ingest/tier-c/run.ts)
# ============================================================================
# The decryption "encryption key" (Day One master key), format D1-<userId>-<code…>.
DAYONE_ENCRYPTION_KEY=

# Auth: either paste a token, OR give email+password to self-mint one.
# DAYONE_API_TOKEN=
DAYONE_EMAIL=
DAYONE_PASSWORD=

# Pin the device identity so repeat runs are the SAME device (else a fresh random
# one is generated each run → registers a new device every time).
# DAYONE_DEVICE_ID=<32-hex>
# DAYONE_X_USER_AGENT=   # optional override; a sensible default is used
# DAYONE_DEVICE_INFO=    # optional full override
