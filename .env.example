# dayone-headless config. Copy to `.env` (gitignored) and fill in.
# NEVER commit real values. The encryption key decrypts the ENTIRE journal —
# treat this file (and the browser profile dir, if used) like a private key at rest.

# ============================================================================
# Production: the REST ingester — pure HTTPS, no browser (src/ingest/rest/)
# This is what `dayone sync`, the CLI, and the Docker image use.
# ============================================================================

# The decryption key (Day One "encryption key"), format D1-<userId>-<code…>.
# Required. In the app: Settings → Encryption.
DAYONE_ENCRYPTION_KEY=

# Auth: either paste a 32-char token, OR give email+password to self-mint one.
# DAYONE_API_TOKEN=
DAYONE_EMAIL=
DAYONE_PASSWORD=

# Pin the device identity (any 32-hex) so repeat runs are the SAME device;
# otherwise a fresh random one is generated each run → registers a new device.
# DAYONE_DEVICE_ID=<32-hex>
# DAYONE_X_USER_AGENT=   # optional override; a sensible default is used
# DAYONE_DEVICE_INFO=    # optional full override

# Optional: mirror db path (default: data/mirror.db — all runtime state under data/).
# DAYONE_MIRROR=./data/mirror.db

# MCP server: set a port to serve streamable-HTTP instead of stdio.
# DAYONE_MCP_PORT=8477
# DAYONE_MCP_HOST=127.0.0.1
# DAYONE_MIRROR_WAIT=300   # seconds the MCP server waits for the mirror on boot
# DAYONE_SYNC_INTERVAL=3600  # seconds between syncs (docker compose loop)


# ============================================================================
# Dev / oracle only: the browser ingester (src/ingest/browser/)
# Drives the web app in headless Chromium as the conformance oracle / fallback.
# NOT used in production and NOT in the Docker image.
# ============================================================================

# Persistent Chromium profile (gitignored). Log in once headed; the session
# (and the encryption key's unlocked state) persists here.
# DAYONE_PROFILE_DIR=./profile

# 0 = headed (needed for the one-time manual login), 1 = headless (unattended).
# DAYONE_HEADLESS=0

# Optional: path to a chromium binary. If unset, the system Chrome is used.
# DAYONE_CHROMIUM=/usr/bin/chromium

# Completeness gate: 1 (default) refuses to write a partial mirror; 0 overrides.
# DAYONE_STRICT=1

# --- Automated login (SCAFFOLD — selectors not yet wired, see login.ts) ---
# Use the typeable encryption-passphrase path, NOT Apple/Secure-Enclave 2FA.
# DAYONE_AUTOMATED_LOGIN=1
# DAYONE_PASSPHRASE=
