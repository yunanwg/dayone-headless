# dayone-headless config for local, non-Compose use. Copy to `.env` (gitignored)
# and fill in. Every shipping REST/MCP secret supports a mutually exclusive
# `_FILE` companion, e.g. DAYONE_ENCRYPTION_KEY_FILE=/run/secrets/dayone_encryption_key.
# NEVER commit real values. The encryption key decrypts the ENTIRE journal.

# ============================================================================
# Production: the REST ingester — pure HTTPS, no browser (src/ingest/rest/)
# This is what `daytwo sync`, the CLI, and the Docker image use.
# ============================================================================

# The decryption key (Day One "encryption key"), format D1-<userId>-<code…>.
# Required. In the app: Settings → Encryption.
DAYONE_ENCRYPTION_KEY=
# DAYONE_ENCRYPTION_KEY_FILE=/absolute/path/to/secret

# Auth: either paste a 32-char token, OR give email+password to self-mint one.
# DAYONE_API_TOKEN=
# DAYONE_API_TOKEN_FILE=/absolute/path/to/secret
# DAYONE_EMAIL=
# DAYONE_PASSWORD=
# DAYONE_EMAIL_FILE=/absolute/path/to/secret
# DAYONE_PASSWORD_FILE=/absolute/path/to/secret

# Pin the device identity (any 32-hex) so repeat runs are the SAME device;
# otherwise a fresh random one is generated each run → registers a new device.
# DAYONE_DEVICE_ID=<32-hex>
# DAYONE_X_USER_AGENT=   # optional override; a sensible default is used
# DAYONE_DEVICE_INFO=    # optional full override
# DAYONE_HTTP_TIMEOUT_MS=60000  # each upstream request; range 1000..300000

# Optional: mirror db path (default: data/mirror.db — all runtime state under data/).
# DAYONE_MIRROR=./data/mirror.db

# Optional: decrypted media byte cache dir (default: data/media). Populated on
# request by `daytwo media-fetch`; gitignored like the mirror.
# DAYONE_MEDIA_DIR=./data/media

# MCP server: set a port to serve streamable-HTTP instead of stdio.
# DAYONE_MCP_PORT=8477
# DAYONE_MCP_HOST=127.0.0.1
# DAYONE_MCP_AUTH_MODE=none  # loopback bind only; static | cloudflare-access otherwise
# DAYONE_MCP_ALLOWED_HOSTS=127.0.0.1:8477,localhost:8477
# DAYONE_MCP_ALLOWED_ORIGINS=  # exact browser Origin values; empty rejects all
# DAYONE_MCP_MAX_CONCURRENCY=8
#
# Static bearer mode (not OAuth; minimum 32 bytes):
# DAYONE_MCP_AUTH_MODE=static
# DAYONE_MCP_TOKEN_FILE=/absolute/path/to/secret
#
# Cloudflare Access mode validates the Access assertion injected by the edge:
# DAYONE_MCP_AUTH_MODE=cloudflare-access
# DAYONE_CF_ACCESS_TEAM_DOMAIN=example.cloudflareaccess.com
# DAYONE_CF_ACCESS_AUD=<application-audience-tag>
# DAYONE_MIRROR_WAIT=300  # integer seconds, range 1-3600
# DAYONE_SYNC_INTERVAL=3600  # integer seconds between syncs, range 60-86400
# DAYONE_SYNC_MAX_STALENESS_SECONDS=86400  # sync health threshold, range 60-604800
# DAYONE_SYNC_CONCURRENCY=8  # integer worker count, range 1-64
# DAYONE_MEDIA_CONCURRENCY=6  # integer worker count, range 1-32


# ============================================================================
# Experimental / unproven: the browser ingester (src/ingest/browser/)
# Drives the web app in headless Chromium. NOT validated end-to-end, NOT used in
# production, NOT in the Docker image. The proven conformance oracle + manual
# fallback is the JSON-export importer (`bun run import`); see docs/architecture.md.
# ============================================================================

# Persistent Chromium profile (gitignored). Log in once headed; the session
# (and the encryption key's unlocked state) persists here.
# DAYONE_PROFILE_DIR=./profile

# 0 = headed (needed for the one-time manual login), 1 = headless (unattended).
# DAYONE_HEADLESS=0

# Optional: path to a chromium binary. If unset, the system Chrome is used.
# DAYONE_CHROMIUM=/usr/bin/chromium

# Completeness gate: 1 (default) refuses to write a partial mirror; 0 overrides.
# DAYONE_STRICT=1

# --- Automated login (SCAFFOLD — selectors not yet wired, see login.ts) ---
# Use the typeable encryption-passphrase path, NOT Apple/Secure-Enclave 2FA.
# DAYONE_AUTOMATED_LOGIN=1
# DAYONE_PASSPHRASE=
